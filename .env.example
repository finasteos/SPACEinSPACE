[TEMPLATE]
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Supabase (https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
# Local: after `supabase start`, paste URL + service_role from `supabase status`
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=  # service_role key (secret)
SUPABASE_KEY=          # alias accepted by shared/supabase_client.py
SUPABASE_ANON_KEY=     # anon public key
DATABASE_URL=          # optional postgres:// for sql/apply_schema.py

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Game engines (from gamedev-mcp-hub) — see docs/game-engines.md
# Default backend is in-memory (no Editor required).
GAME_ENGINE_BACKEND=memory
UNITY_PROJECT_PATH=
UNITY_EDITOR_PATH=
UNITY_MCP_PACKAGE=@nurture-tech/unity-mcp-runner
GODOT_PROJECT_PATH=
GODOT_EDITOR_PATH=
GODOT_MCP_PACKAGE=godot-mcp
# Optional art/gen keys for catalog in config/game-engines.json
PIXELLAB_API_KEY=
MESHY_API_KEY=

# Logging
LOG_LEVEL=INFO
