{
  "servers": {
    "unity-nurture": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@nurture-tech/unity-mcp-runner"],
      "category": "game-engine",
      "priority": "high",
      "description": "Unity Engine via nurture-tech MCP (external backend)",
      "env": {
        "UNITY_PROJECT_PATH": "${UNITY_PROJECT_PATH}",
        "UNITY_EDITOR_PATH": "${UNITY_EDITOR_PATH}"
      }
    },
    "godot": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "godot-mcp"],
      "category": "game-engine",
      "priority": "high",
      "description": "Godot Engine MCP (external backend)",
      "env": {
        "GODOT_PROJECT_PATH": "${GODOT_PROJECT_PATH}",
        "GODOT_EDITOR_PATH": "${GODOT_EDITOR_PATH}"
      }
    },
    "unreal": {
      "enabled": false,
      "command": "node",
      "args": ["path/to/UnrealMCP/dist/index.js"],
      "category": "game-engine",
      "priority": "medium",
      "description": "Unreal Engine integration (scaffold — not wired yet)"
    },
    "pixellab": {
      "enabled": true,
      "command": "python",
      "args": ["-m", "mcp_servers.pixellab_mcp_server"],
      "category": "art-generation",
      "priority": "high",
      "description": "PixelLab pixel art (in-process ambassador; stub without key)",
      "env": {
        "PIXELLAB_API_KEY": "${PIXELLAB_API_KEY}"
      }
    },
    "meshy": {
      "enabled": true,
      "command": "python",
      "args": ["-m", "mcp_servers.meshy_mcp_server"],
      "category": "3d-generation",
      "priority": "high",
      "description": "Meshy text/image-to-3D (in-process ambassador; stub without key)",
      "env": {
        "MESHY_API_KEY": "${MESHY_API_KEY}"
      }
    },
    "opgg": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@opgginc/opgg-mcp"],
      "category": "analytics",
      "priority": "low",
      "description": "Gaming analytics"
    }
  },
  "_comment": "In-process ambassadors: unity/godot/pixellab/meshy via mcp_servers/*. External packages remain optional bridges."
}
